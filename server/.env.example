# =============================================================
# WorkTrack — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# =============================================================

# ─── DATABASE ─────────────────────────────────────────────────
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:yourpassword@localhost:3306/worktrack"

# ─── SERVER ───────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── JWT ──────────────────────────────────────────────────────
# Use long random strings — minimum 64 characters each
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_string
JWT_REFRESH_SECRET=replace_with_different_64_char_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────
# Frontend URL (Vite default)
CORS_ORIGIN=http://localhost:5173

# ─── RATE LIMITING ────────────────────────────────────────────
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=100
API_RATE_LIMIT_WINDOW_MS=900000
